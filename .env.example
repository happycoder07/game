# Vercel (frontend)
# After Render deploy, set this in Vercel Project → Settings → Environment Variables
# and redeploy the client:
# VITE_SOCKET_URL=https://twenty-nine-api.onrender.com

# Game server (Render / Docker)
# CORS_ORIGIN=https://twenty-nine-ten.vercel.app,http://localhost:5173
# PORT=3001
# HOST=0.0.0.0
# DATABASE_URL=file:/tmp/twenty-nine.db
